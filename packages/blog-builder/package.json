{
    "name": "@blog/blog-builder",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --banner:js=\"#!/usr/bin/env node\" --outfile=dist/blog-builder.js",
        "verify": "npm run typecheck && npm test",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "@blog/shared": "*",
        "node-html-parser": "^7.0.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "esbuild": "^0.27.3",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
