{
    "name": "@blog/blog-viewer",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "deploy": "node --input-type=module -e \"import{copyFileSync}from'node:fs';copyFileSync('dist/blog-viewer.js','../../content/blog-viewer.js')\"",
        "build": "esbuild src/blog-viewer.tsx --bundle --platform=browser --format=esm --outfile=dist/blog-viewer.js",
        "verify": "npm run typecheck && npm test",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "@blog/shared": "*",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.0.0",
        "@testing-library/react": "^16.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "esbuild": "^0.27.3",
        "jsdom": "^26.0.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
